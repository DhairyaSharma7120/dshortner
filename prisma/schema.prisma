generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  links         Link[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id          String    @id @default(cuid())
  shortCode   String    @unique
  originalUrl String
  customAlias String?   @unique
  clickCount  Int       @default(0)
  expiresAt   DateTime?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  clicks      Click[]
  user        User      @relation(fields: [userId], references: [id])
}

model Click {
  id        String   @id @default(cuid())
  linkId    String
  ipAddress String?
  userAgent String?
  referrer  String?
  country   String?
  city      String?
  createdAt DateTime @default(now())
  link      Link     @relation(fields: [linkId], references: [id])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
